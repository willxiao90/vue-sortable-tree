{
  "name": "sortable-tree-vue3",
  "author": "willxiao90",
  "private": false,
  "version": "1.0.0",
  "license": "MIT",
  "keywords": [
    "vue",
    "tree",
    "sortable",
    "nested",
    "draggable",
    "dnd",
    "drag-n-drop",
    "drag-and-drop",
    "drag",
    "drop",
    "tree-view",
    "tree-structure",
    "treeview"
  ],
  "homepage": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/willxiao90/sortable-tree-vue3.git"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/vue-sortable-tree.umd.cjs",
  "module": "./dist/vue-sortable-tree.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue-sortable-tree.js",
      "require": "./dist/vue-sortable-tree.umd.cjs"
    },
    "./style.css": "./dist/vue-sortable-tree.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build-example": "vue-tsc --noEmit && vite build --config vite.config.example.ts",
    "preview": "vite preview --config vite.config.example.ts"
  },
  "dependencies": {
    "sortablejs": "^1.15.7"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/sortablejs": "^1.15.9",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-dts": "^4.5.4",
    "vue-tsc": "^3.1.4"
  }
}
